<configuration>
    <property name="DOCFINDER_BASE_DIR" value="${user.dir}/.docfinder"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${DOCFINDER_BASE_DIR}/logs/docfinder.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${DOCFINDER_BASE_DIR}/logs/docfinder.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>300MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>


    <!-- Suppress known non-fatal Apache POI noise emitted during Tika extraction.
         These warnings are about editability/format edge-cases and do not block read-only indexing. -->
    <logger name="org.apache.poi.xssf.usermodel.XSSFDrawing" level="ERROR"/>
    <logger name="org.apache.poi.ss.usermodel.DataFormatter" level="ERROR"/>

    <root level="info">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
